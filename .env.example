NODE_ENV=development
PORT=3000

DATABASE_URL=postgres://postgres:123@localhost:5432/swiftydoc
DATABASE_POOL_MAX=10
DATABASE_SSL=false
AUTH_BOOTSTRAP_ALLOW_SIGNUP=true
INTERNAL_AUTH_ACCESS_TOKEN_TTL_MINUTES=60
INTERNAL_AUTH_REFRESH_TOKEN_TTL_DAYS=30
INTERNAL_AUTH_INVITE_TOKEN_TTL_HOURS=72
INTERNAL_AUTH_INVITE_URL_BASE=http://localhost:3000/accept-invite
INTERNAL_AUTH_EMAIL_VERIFICATION_URL_BASE=http://localhost:3000/verify-email
INTERNAL_AUTH_PASSWORD_RESET_URL_BASE=http://localhost:3000/reset-password
PORTAL_AUTH_TOKEN_TTL_MINUTES=30
PORTAL_AUTH_TOKEN_SECRET=swiftydoc-portal-auth-secret-local-1234567890
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120
WEBHOOK_DELIVERY_TIMEOUT_MS=5000
FILE_UPLOAD_MAX_BYTES=10485760
FILE_UPLOAD_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp,text/plain,text/csv,application/zip,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage

BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_REGION=
BUNNY_STORAGE_API_KEY=
BUNNY_PULL_ZONE_BASE_URL=

WHATSAPP_CLOUD_API_BASE_URL=https://graph.facebook.com

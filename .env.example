NODE_ENV=development
PORT=3000

DATABASE_URL=postgres://postgres:123@localhost:5432/swiftydoc
DATABASE_POOL_MAX=10
DATABASE_SSL=false
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120
WEBHOOK_DELIVERY_TIMEOUT_MS=5000
FILE_UPLOAD_MAX_BYTES=10485760
FILE_UPLOAD_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp,text/plain,text/csv,application/zip,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage

BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_REGION=
BUNNY_STORAGE_API_KEY=
BUNNY_PULL_ZONE_BASE_URL=

WHATSAPP_CLOUD_API_BASE_URL=https://graph.facebook.com
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_API_PHONE_NUMBER_ID=

PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=

RESEND_API_KEY=
RESEND_DEFAULT_FROM_EMAIL=

ZOHO_BOOKS_API_BASE_URL=https://www.zohoapis.com/books/v3
ZOHO_BOOKS_ACCESS_TOKEN=
ZOHO_BOOKS_ORGANIZATION_ID=

SEED_ORGANIZATION_ID=org_demo
SEED_ORGANIZATION_SLUG=seed-org-demo
SEED_BOOTSTRAP_DEMO_ORG=true
SEED_BRAND_DISPLAY_NAME=SwiftyDoc Demo
SEED_BRAND_LOGO_URL=
SEED_BRAND_PRIMARY_COLOR=#0A1F44
SEED_BRAND_SECONDARY_COLOR=#14B8A6
SEED_BRAND_EMAIL_FROM_NAME=SwiftyDoc Demo Team
SEED_BRAND_EMAIL_REPLY_TO=support@example.com
SEED_TEMPLATE_LOCALE=en
SEED_RESEND_TEMPLATE_ID=